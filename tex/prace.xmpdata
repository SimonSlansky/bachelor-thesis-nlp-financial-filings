\Author{Šimon Slanský}
\Title{Textual-Financial Divergence and Stock Return Volatility: Evidence from U.S. Corporate Filings}
\Keywords{textual analysis\sep 10-K filings\sep SEC EDGAR\sep volatility\sep information uncertainty\sep narrative divergence}
\Subject{This thesis investigates whether textual-financial divergence in 10-K filings predicts future stock return volatility beyond financial variables and textual features alone.}
\Publisher{Prague University of Economics and Business, Faculty of Informatics and Statistics}
